NEWSINTEL_ENVIRONMENT=development
NEWSINTEL_LOG_LEVEL=INFO
NEWSINTEL_API_HOST=127.0.0.1
NEWSINTEL_API_PORT=8010
NEWSINTEL_PUBLIC_BASE_URL=http://127.0.0.1:8010
NEWSINTEL_DATABASE_URL=postgresql+asyncpg://newsintel:newsintel@localhost:5432/newsintel
NEWSINTEL_DATABASE_CONNECT_TIMEOUT_SECONDS=5
NEWSINTEL_REDIS_URL=redis://localhost:6379/0
NEWSINTEL_QDRANT_URL=http://localhost:6333
NEWSINTEL_OBJECT_STORE_ENDPOINT=http://localhost:9000
NEWSINTEL_OBJECT_STORE_BUCKET=newsintel
NEWSINTEL_OBJECT_STORE_ACCESS_KEY=newsintel
NEWSINTEL_OBJECT_STORE_SECRET_KEY=change-me
NEWSINTEL_CRAWLER_USER_AGENT=NewsIntelligenceBot/0.1 (+https://example.invalid/crawler)

# Authentication is disabled by default in local templates.
# For local-only development without an identity provider, set this explicitly:
# NEWSINTEL_DEV_AUTH_BYPASS_ENABLED=true
NEWSINTEL_AUTH_MODE=disabled
NEWSINTEL_AUTH_PROVIDER_NAME=oidc
NEWSINTEL_AUTH_JWT_ISSUER=
NEWSINTEL_AUTH_JWT_AUDIENCE=
NEWSINTEL_AUTH_JWT_JWKS_URL=
NEWSINTEL_AUTH_JWT_ALGORITHMS=RS256
NEWSINTEL_AUTH_JWT_HS256_SECRET=
NEWSINTEL_AUTH_OIDC_AUTHORIZATION_URL=
NEWSINTEL_AUTH_OIDC_TOKEN_URL=
NEWSINTEL_AUTH_OIDC_CLIENT_ID=
NEWSINTEL_AUTH_OIDC_CLIENT_SECRET=
NEWSINTEL_AUTH_OIDC_REDIRECT_URI=http://127.0.0.1:8010/auth/callback
NEWSINTEL_AUTH_SESSION_SECRET=
NEWSINTEL_AUTH_COOKIE_SECURE=false
NEWSINTEL_AUTH_COOKIE_SAMESITE=lax
NEWSINTEL_DEV_AUTH_BYPASS_ENABLED=false
NEWSINTEL_BOOTSTRAP_OWNER_PROVIDER=
NEWSINTEL_BOOTSTRAP_OWNER_USER_ID=
NEWSINTEL_BOOTSTRAP_OWNER_EMAIL=
NEWSINTEL_CORS_ALLOWED_ORIGINS=

NEWSINTEL_RAW_ARTIFACT_STORE_BACKEND=local
NEWSINTEL_S3_ARTIFACT_PREFIX=raw-html
NEWSINTEL_S3_ARTIFACT_SSE=
NEWSINTEL_POLL_WORKER_BATCH_SIZE=20
NEWSINTEL_POLL_WORKER_CONCURRENCY=5
NEWSINTEL_POLL_WORKER_LEASE_SECONDS=120
NEWSINTEL_POLL_WORKER_IDLE_SECONDS=2
NEWSINTEL_OUTBOX_WORKER_BATCH_SIZE=50
NEWSINTEL_OUTBOX_WORKER_IDLE_SECONDS=2
NEWSINTEL_DATABASE_RETRY_MAX_SECONDS=30
NEWSINTEL_ARTICLE_WORKER_BATCH_SIZE=20
NEWSINTEL_ARTICLE_WORKER_CONCURRENCY=5
NEWSINTEL_ARTICLE_WORKER_LEASE_SECONDS=120
NEWSINTEL_ARTICLE_WORKER_IDLE_SECONDS=2
NEWSINTEL_ARTICLE_FETCH_MAX_ATTEMPTS=3
NEWSINTEL_ARTICLE_FETCH_RETRY_BASE_SECONDS=120
NEWSINTEL_ARTICLE_FETCH_RETRY_MAX_SECONDS=3600
NEWSINTEL_ARTICLE_FETCH_RETRY_JITTER_RATIO=0.15
NEWSINTEL_RECENT_ARTICLE_WINDOW_HOURS=48
NEWSINTEL_MAX_NEW_URLS_PER_CHANNEL_POLL=200
NEWSINTEL_MAX_NEW_URLS_PER_PUBLISHER_FETCH=300
NEWSINTEL_MAX_NEW_URLS_PER_FETCH_JOB=2000
NEWSINTEL_MAX_ACTIVE_CHANNELS_PER_PUBLISHER=25
NEWSINTEL_DISCOVERY_RECOVERY_WINDOW_DAYS=7
NEWSINTEL_INITIAL_BACKFILL_DAYS=3
NEWSINTEL_MAX_RETRIES=3
NEWSINTEL_WORKER_LEASE_SECONDS=120
NEWSINTEL_DEAD_LETTER_AFTER_ATTEMPTS=3

# Local AI only. No paid API fallback is enabled.
NEWSINTEL_AI_PROVIDER=disabled
NEWSINTEL_LOCAL_MODEL_BASE_URL=http://localhost:11434
